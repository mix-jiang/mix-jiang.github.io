---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Mix Jiang — experience designer & product manager, working the AI-native way.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-Hans">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <slot />
  <footer class="footer">
    <p>
      © {new Date().getFullYear()} Mix Jiang · Ginger Works
      <span class="footer-links">
        <a href="mailto:mixitaliano@gmail.com">Email</a>
        <a href="https://www.linkedin.com/in/mingxuan-jiang-31a0a392/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://www.instagram.com/mix_j" target="_blank" rel="noopener">Instagram</a>
        <a href="https://github.com/mix-jiang" target="_blank" rel="noopener">GitHub</a>
      </span>
    </p>
  </footer>
</body>
</html>
