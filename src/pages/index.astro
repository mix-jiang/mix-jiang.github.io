---
import Base from '../layouts/Base.astro';
---
<Base title="Mix Jiang — Product Designer · Hong Kong" locked={true} showLangToggle={true}>
  <main class="home" id="about">
    <div class="home-photos">
      <div class="photo-main">
        <img src="https://framerusercontent.com/images/OQOQXHYWzmcifotmOiW0zH4M.png?width=1116&height=1596" alt="Mix Jiang portrait" />
      </div>
      <div class="photo-sm">
        <img src="https://framerusercontent.com/images/85syzp8D1Mwskw7JUqQcqp1DoY.jpg?width=501&height=851" alt="Snowboarding / cycling" />
      </div>
      <div class="photo-sm">
        <img src="https://framerusercontent.com/images/p5Sl16hp4Txai79vi0N1iOmBjw.jpg?width=1080&height=2249" alt="Travel / live" />
      </div>
    </div>

    <div class="home-text">
      <div class="kicker" data-en="PRODUCT DESIGNER · HONG KONG" data-zh="产品设计师 · 香港">PRODUCT DESIGNER · HONG KONG</div>
      <div>
        <div class="home-name">Jiang Mingxuan</div>
        <div class="home-desc" data-en="Product designer — fintech experiences for millions of users. Now exploring AI-native ways of building." data-zh="产品设计师 — 服务数百万用户的金融科技体验,正在探索 AI-native 的构建方式。">Product designer — fintech experiences for millions of users. Now exploring AI-native ways of building.</div>
      </div>

      <div class="now">
        <div class="now-head">
          <span class="kicker" data-en="RECENT" data-zh="最近">RECENT</span>
          <span class="now-live">● <span data-en="in progress" data-zh="进行中">in progress</span></span>
        </div>
        <div class="now-list">
          <div class="now-row">
            <span class="now-date" data-en="Now" data-zh="至今">Now</span>
            <a href="/about/" data-en="WeChat Pay HK — Experience Designer & Product Manager" data-zh="WeChat Pay HK — 体验设计师 + 产品经理">WeChat Pay HK — Experience Designer &amp; Product Manager</a>
          </div>
          <div class="now-row">
            <span class="now-date">2026-06</span>
            <a href="/projects/investing-assistant/" data-en="Investing Assistant — multi-source investing research" data-zh="Investing Assistant — 多信源投资研究系统">Investing Assistant — multi-source investing research</a>
          </div>
          <div class="now-row">
            <span class="now-date">2026-04</span>
            <a href="/projects/digital-twin/" data-en="Digital Twin — personal context system" data-zh="Digital Twin — 个人上下文系统">Digital Twin — personal context system</a>
          </div>
          <div class="now-row is-muted">
            <span class="now-date">2026-07</span>
            <span data-en="Writing: AI-native workflow in practice" data-zh="AI-native 工作流实践">Writing: AI-native workflow in practice</span>
            <span class="now-draft" data-en="drafting…" data-zh="写作中…">drafting…</span>
          </div>
        </div>
      </div>

      <div class="chips-block">
        <div class="kicker">OFF SCREEN</div>
        <div class="chips">
          <span class="chip" data-en="snowboarding" data-zh="滑雪 snowboarding">snowboarding</span>
          <span class="chip" data-en="road cycling" data-zh="公路车 road cycling">road cycling</span>
          <span class="chip" data-en="boxing" data-zh="拳击 boxing">boxing</span>
          <span class="chip" data-en="kitesurfing" data-zh="风筝冲浪 kitesurfing">kitesurfing</span>
          <span class="chip" data-en="electronic music" data-zh="电子音乐 electronic music">electronic music</span>
          <span class="chip" data-en="car culture" data-zh="汽车文化 car culture">car culture</span>
        </div>
      </div>
    </div>
  </main>

  <script>
    const apply = (lang: string) => {
      document.querySelectorAll<HTMLElement>('[data-en]').forEach((el) => {
        const v = el.dataset[lang as 'en' | 'zh'];
        if (v) el.textContent = v;
      });
      document.getElementById('lang-en')?.classList.toggle('is-active', lang === 'en');
      document.getElementById('lang-zh')?.classList.toggle('is-active', lang === 'zh');
      try { localStorage.setItem('lang', lang); } catch {}
    };
    document.getElementById('lang-en')?.addEventListener('click', () => apply('en'));
    document.getElementById('lang-zh')?.addEventListener('click', () => apply('zh'));
    let saved = 'en';
    try { saved = localStorage.getItem('lang') || 'en'; } catch {}
    if (saved === 'zh') apply('zh');
  </script>
</Base>
