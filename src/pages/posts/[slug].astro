---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('posts', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---
<Base title={`${d.title} — Mix Jiang`} description={d.summary}>
  <main class="page-scroll">
    <article class="article-simple">
      <a class="back-link" href="/projects/">← back</a>
      <div class="kicker">POST · {d.date}{d.tags.length > 0 && ` · ${d.tags.join(' · ').toUpperCase()}`}</div>
      <h1>{d.title}</h1>
      <p class="article-summary">{d.summary}</p>
      <Content />
    </article>
  </main>
</Base>
